# freelancekg server configuration

# runtime
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# core
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/freelancekg
# valkey/redis endpoint (valkey-cli ping / redis-cli ping)
REDIS_URL=redis://127.0.0.1:6379

# auth (at least 32 characters each)
JWT_SECRET=change-me-with-at-least-32-characters
SESSION_SECRET=change-me-with-at-least-32-characters
JWT_EXPIRES_IN=7d

# frontend and cors
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# smtp (mailpit in local docker: host=localhost port=1025)
# optional in production; if omitted, emails are logged only
EMAIL_FROM=noreply@freelancekg.kg
EMAIL_REPLY_TO=support@freelancekg.kg
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_API_BASE=
TELEGRAM_LINK_SECRET=change-me-with-at-least-16-characters
TELEGRAM_LINK_TTL_SECONDS=900

# storage
# for free cloud deploys, local storage works but uploaded files are not durable
# use STORAGE_PROVIDER=s3 for persistent media
STORAGE_PROVIDER=local
S3_PUBLIC_BASE_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=60
MESSAGE_RATE_LIMIT_MAX=300
UPLOAD_RATE_LIMIT_MAX=120

# payments
# quick deploy recommendation: PAYMENT_PROVIDER=disabled
PAYMENT_PROVIDER=mock
PAYBOX_MERCHANT_ID=
PAYBOX_SECRET_KEY=
PAYBOX_API_BASE=

# oauth
# quick deploy recommendation: ENABLE_OAUTH=false until provider credentials are configured
ENABLE_OAUTH=true
DEV_OAUTH_MOCK=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# files
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
