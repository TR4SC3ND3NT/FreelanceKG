# compose defaults (used by docker compose variable substitution)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=freelancekg
REDIS_PASSWORD=redis123

# app runtime
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/freelancekg
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-me-with-at-least-32-characters
SESSION_SECRET=change-me-with-at-least-32-characters
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost
CORS_ORIGIN=http://localhost
PORT=3001

# email
EMAIL_FROM=noreply@freelancekg.kg
EMAIL_REPLY_TO=support@freelancekg.kg
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# oauth
ENABLE_OAUTH=false
DEV_OAUTH_MOCK=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# payments
PAYMENT_PROVIDER=mock
PAYBOX_MERCHANT_ID=
PAYBOX_SECRET_KEY=
PAYBOX_API_BASE=

# frontend local dev overrides
VITE_API_ORIGIN=http://localhost:3001
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001
