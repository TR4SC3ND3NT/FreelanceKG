# dependencies
node_modules/
.pnp
.pnp.js

# build outputs
dist/
build/
.next/
out/
.cache/
.temp/
.tmp/
*.tsbuildinfo

# environment files (keep only templates)
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.template
!**/.env.example
!**/.env.template

# secrets and certificates
*.pem
*.key
*.p12
*.pfx
id_rsa*
*.crt

# database dumps and local db files
*.sql
*.dump
*.bak
*.sqlite
*.sqlite3
*.db
*.db-journal

# runtime container data
/data/
/db-data/
/pgdata/
/.postgres/
/.mysql/
/volumes/
/server/backups/
.local-postgres/

# keep prisma migrations under version control
!server/prisma/migrations/**/migration.sql

# logs and pid/runtime files
logs/
server/logs/
nginx/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock
.pids/

# coverage and tests
coverage/
.nyc_output/
.jest/
__snapshots__/

# ide and os files
.idea/
.vscode/
.codex
*.swp
*.swo
*~
.DS_Store

# uploads (keep directory, ignore files)
server/uploads/*
!server/uploads/.gitkeep
